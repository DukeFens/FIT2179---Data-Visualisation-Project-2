{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 320,
  "background": null,
  "config": { "view": { "stroke": null } },
  "data": { "url": "../data/badminton_participation_by_age_gender.csv" },
  "transform": [
    {
      "calculate": "datum.gender === 'Male' ? -datum.participants_thousands : datum.participants_thousands",
      "as": "participants_signed"
    }
  ],
  "layer": [
    {
      "comment": "── Bars ──",
      "mark": { "type": "bar", "cornerRadiusTopLeft": 2, "cornerRadiusTopRight": 2, "cornerRadiusBottomLeft": 2, "cornerRadiusBottomRight": 2 },
      "encoding": {
        "y": {
          "field": "age_group", "type": "ordinal",
          "sort": ["15-17","18-24","25-34","35-44","45-54","55-64","65+"],
          "axis": { "title": "Age group", "titleFontSize": 10.5, "labelFontSize": 11 }
        },
        "x": {
          "field": "participants_signed", "type": "quantitative",
          "axis": {
            "title": "← Male        Female →",
            "titleFontSize": 10.5,
            "labelExpr": "abs(datum.value)"
          },
          "scale": { "domain": [-80, 80] }
        },
        "color": {
          "field": "gender", "type": "nominal",
          "scale": { "domain": ["Male","Female"], "range": ["#8B5318","#DFA054"] },
          "legend": { "title": "Gender", "orient": "bottom-right", "titleFontSize": 10, "labelFontSize": 10 }
        },
        "tooltip": [
          { "field": "age_group", "title": "Age group" },
          { "field": "gender", "title": "Gender" },
          { "field": "participants_thousands", "title": "Players (thousands)", "format": ".1f" },
          { "field": "participation_rate_pct", "title": "Participation rate (%)", "format": ".1f" }
        ]
      }
    },
    {
      "comment": "── 18-24 highlight annotation ──",
      "data": { "values": [{ "age_group": "18-24", "note": "University age — largest cohort" }] },
      "mark": { "type": "text", "align": "right", "dx": -4, "fontSize": 10, "color": "#8B5318", "fontWeight": "bold", "fontStyle": "italic" },
      "encoding": {
        "y": {
          "field": "age_group", "type": "ordinal",
          "sort": ["15-17","18-24","25-34","35-44","45-54","55-64","65+"]
        },
        "x": { "value": 400 },
        "text": { "field": "note" }
      }
    }
  ],
  "autosize": { "type": "fit", "contains": "padding" },
  "padding": 4
}