{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Point map — badminton venue locations in Melbourne, sized by number of courts",
  "width": 560,
  "height": 420,
  "background": "white",
  "config": {
    "view": { "stroke": null },
    "font": "Segoe UI, Helvetica Neue, Arial, sans-serif",
    "legend": { "labelFontSize": 10, "titleFontSize": 10 }
  },

  "projection": {
    "type": "mercator",
    "center": [145.0, -37.83],
    "scale": 55000
  },

  "layer": [
    {
      "comment": "── Melbourne/Victoria base map ──",
      "data": {
        "url": "https://raw.githubusercontent.com/rowanhogan/australian-states/master/states.min.geojson",
        "format": { "type": "json", "property": "features" }
      },
      "transform": [{ "filter": "datum.properties.STATE_NAME === 'Victoria'" }],
      "mark": { "type": "geoshape", "fill": "#EAF4F8", "stroke": "#B8D8E8", "strokeWidth": 1.2 }
    },
    {
      "comment": "── Venue dots ──",
      "data": { "url": "../data/melbourne_badminton_venues.csv" },
      "mark": { "type": "circle", "opacity": 0.88, "stroke": "white", "strokeWidth": 1.5 },
      "encoding": {
        "longitude": { "field": "longitude", "type": "quantitative" },
        "latitude":  { "field": "latitude",  "type": "quantitative" },
        "size": {
          "field": "courts",
          "type": "quantitative",
          "scale": { "range": [80, 700] },
          "legend": { "title": "No. of courts", "orient": "bottom-right" }
        },
        "color": {
          "field": "near_university",
          "type": "nominal",
          "scale": {
            "domain": ["No", "Yes - Monash University", "Yes - Monash Caulfield", "Yes - RMIT", "Yes - UniMelb"],
            "range": ["#2B88A1", "#D94F35", "#F5A623", "#7B4FBF", "#27AE60"]
          },
          "legend": {
            "title": "Near University",
            "orient": "top-left",
            "labelLimit": 200,
            "titleFontSize": 10,
            "labelFontSize": 10
          }
        },
        "tooltip": [
          { "field": "name",            "title": "Venue" },
          { "field": "suburb",          "title": "Suburb" },
          { "field": "courts",          "title": "Courts" },
          { "field": "type",            "title": "Type" },
          { "field": "near_university", "title": "Near University" }
        ]
      }
    }
  ],

  "title": {
    "text": "Find Your Court in Melbourne",
    "subtitle": "Badminton venues across Greater Melbourne · Colour = proximity to universities · Source: Badminton Victoria & OpenStreetMap",
    "fontSize": 15,
    "subtitleFontSize": 10,
    "subtitleColor": "#666",
    "anchor": "start"
  }
}
