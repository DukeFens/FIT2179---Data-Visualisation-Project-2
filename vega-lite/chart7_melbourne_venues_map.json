{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 400,
  "background": "#D6E8F0",
  "config": { "view": { "stroke": null } },
  "projection": {
    "type": "mercator",
    "center": [145.0, -37.83],
    "scale": 55000
  },
  "layer": [
    {
      "comment": "── Victoria base map ──",
      "data": {
        "url": "data/aus_states_mainland.geojson",
        "format": { "type": "json", "property": "features" }
      },
      "transform": [{ "filter": "datum.properties.STATE_NAME === 'Victoria'" }],
      "mark": {
        "type": "geoshape",
        "fill": "#EBE7DF",
        "stroke": "#FFFFFF",
        "strokeWidth": 1.5
      }
    },
    {
      "comment": "── Venue dots ──",
      "data": { "url": "data/melbourne_badminton_venues.csv" },
      "mark": { "type": "circle", "opacity": 0.85, "stroke": "#FAFAF7", "strokeWidth": 1.5 },
      "encoding": {
        "longitude": { "field": "longitude", "type": "quantitative" },
        "latitude":  { "field": "latitude",  "type": "quantitative" },
        "size": {
          "field": "courts", "type": "quantitative",
          "scale": { "range": [80, 700] },
          "legend": {
            "title": "No. of courts",
            "orient": "bottom-right",
            "titleColor": "#1A1916",
            "labelColor": "#3D3B35"
          }
        },
        "color": {
          "field": "near_university", "type": "nominal",
          "scale": {
            "domain": ["No","Yes - Monash University","Yes - Monash Caulfield","Yes - RMIT","Yes - UniMelb"],
            "range": ["#C8C4BC","#C47D2A","#DFA054","#8B5318","#EEC98A"]
          },
          "legend": {
            "title": "Near University",
            "orient": "top-left",
            "labelLimit": 200,
            "titleFontSize": 10,
            "labelFontSize": 10,
            "titleColor": "#1A1916",
            "labelColor": "#3D3B35",
            "fillColor": "rgba(255,255,255,0.7)",
            "padding": 6,
            "cornerRadius": 4
          }
        },
        "tooltip": [
          { "field": "name",           "title": "Venue" },
          { "field": "suburb",         "title": "Suburb" },
          { "field": "courts",         "title": "Courts" },
          { "field": "type",           "title": "Type" },
          { "field": "near_university","title": "Near University" }
        ]
      }
    }
  ],
  "padding": 4
}