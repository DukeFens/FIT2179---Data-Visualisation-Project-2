{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 320,
  "data": {
    "url": "data/melbourne_lga_courts.csv"
  },
  "config": {
    "view": {
      "stroke": null
    },
    "font": "Inter, sans-serif"
  },
  "layer": [
    {
      "comment": "\u2500\u2500 Regression trend line \u2500\u2500",
      "mark": {
        "type": "line",
        "color": "#C8D5CB",
        "strokeWidth": 1.5,
        "strokeDash": [
          4,
          3
        ]
      },
      "transform": [
        {
          "regression": "courts",
          "on": "asian_born_pct_2021"
        }
      ],
      "encoding": {
        "x": {
          "field": "asian_born_pct_2021",
          "type": "quantitative"
        },
        "y": {
          "field": "courts",
          "type": "quantitative"
        }
      }
    },
    {
      "comment": "\u2500\u2500 LGA scatter dots \u2500\u2500",
      "mark": {
        "type": "circle",
        "opacity": 0.85,
        "stroke": "#F3F6F0",
        "strokeWidth": 1.5
      },
      "encoding": {
        "x": {
          "field": "asian_born_pct_2021",
          "type": "quantitative",
          "title": "Asian-born residents, 2021 Census (%)",
          "axis": {
            "grid": true,
            "gridColor": "#E8EDE9",
            "domainColor": "#C8D5CB",
            "tickColor": "#C8D5CB",
            "labelFontSize": 11,
            "labelExpr": "datum.value + '%'"
          }
        },
        "y": {
          "field": "courts",
          "type": "quantitative",
          "title": "Badminton courts in LGA",
          "axis": {
            "grid": true,
            "gridColor": "#E8EDE9",
            "domainColor": "#C8D5CB",
            "tickColor": "#C8D5CB",
            "labelFontSize": 11
          }
        },
        "size": {
          "field": "population_2021",
          "type": "quantitative",
          "scale": {
            "range": [
              40,
              500
            ]
          },
          "legend": {
            "orient": "bottom",
            "title": "LGA Population (dot size)",
            "format": "~s",
            "direction": "horizontal",
            "gradientLength": 100,
            "symbolFillColor": "#9DBBA8",
            "symbolStrokeColor": "#F3F6F0"
          }
        },
        "color": {
          "field": "courts",
          "type": "quantitative",
          "scale": {
            "scheme": "greens",
            "domain": [
              0,
              25
            ]
          },
          "legend": null
        },
        "tooltip": [
          {
            "field": "lga",
            "title": "LGA"
          },
          {
            "field": "asian_born_pct_2021",
            "title": "Asian-born (%)",
            "format": ".1f"
          },
          {
            "field": "courts",
            "title": "Courts"
          },
          {
            "field": "population_2021",
            "title": "Population",
            "format": ","
          }
        ]
      }
    },
    {
      "comment": "\u2500\u2500 Labels: left-side / middle LGAs (label sits to the right of dot) \u2500\u2500",
      "transform": [
        {
          "filter": "(datum.courts >= 12 || datum.asian_born_pct_2021 >= 35) && datum.asian_born_pct_2021 < 36"
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 9,
        "dy": -2,
        "fontSize": 11,
        "fontWeight": "600",
        "color": "#172821"
      },
      "encoding": {
        "x": {
          "field": "asian_born_pct_2021",
          "type": "quantitative"
        },
        "y": {
          "field": "courts",
          "type": "quantitative"
        },
        "text": {
          "field": "label"
        }
      }
    },
    {
      "comment": "\u2500\u2500 Labels: right-edge LGAs (label sits to the left of dot so it stays inside the plot) \u2500\u2500",
      "transform": [
        {
          "filter": "(datum.courts >= 12 || datum.asian_born_pct_2021 >= 35) && datum.asian_born_pct_2021 >= 36"
        }
      ],
      "mark": {
        "type": "text",
        "align": "right",
        "dx": -9,
        "dy": -2,
        "fontSize": 11,
        "fontWeight": "600",
        "color": "#172821"
      },
      "encoding": {
        "x": {
          "field": "asian_born_pct_2021",
          "type": "quantitative"
        },
        "y": {
          "field": "courts",
          "type": "quantitative"
        },
        "text": {
          "field": "label"
        }
      }
    }
  ],
  "title": {
    "anchor": "start",
    "fontSize": 13,
    "subtitleFontSize": 10,
    "color": "#172821",
    "subtitleColor": "#506158",
    "offset": 8,
    "text": "Asian-born population vs. badminton courts by LGA",
    "subtitle": "Dot size = LGA population; trend line shows positive correlation."
  }
}