{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 300,
  "background": null,
  "config": { "view": { "stroke": null } },
  "data": { "url": "../data/australian_players_bwf_rankings.csv" },
  "params": [
    {
      "name": "playerSelect",
      "select": { "type": "point", "fields": ["player"] },
      "bind": "legend"
    }
  ],
  "layer": [
    {
      "comment": "── Lines per player ──",
      "mark": { "type": "line", "point": { "size": 65 }, "strokeWidth": 2.5 },
      "encoding": {
        "x": {
          "field": "year", "type": "ordinal",
          "axis": { "title": null, "labelFontSize": 11 }
        },
        "y": {
          "field": "world_ranking", "type": "quantitative",
          "scale": { "reverse": true },
          "axis": { "title": "BWF World Ranking (lower = better)", "titleFontSize": 10.5 }
        },
        "color": {
          "field": "player", "type": "nominal",
          "scale": {
            "domain": ["Tiffany Ho","Setyana Mapasa","Angela Yu","Gronya Sommerville"],
            "range": ["#8B5318","#C47D2A","#DFA054","#EEC98A"]
          },
          "legend": {
            "title": "Player (click to highlight)",
            "orient": "top-right",
            "titleFontSize": 10,
            "labelFontSize": 10
          }
        },
        "strokeDash": {
          "field": "discipline", "type": "nominal",
          "scale": {
            "domain": ["Women's Singles","Women's Doubles","Mixed Doubles"],
            "range": [[1,0],[4,2],[2,2]]
          },
          "legend": {
            "title": "Discipline",
            "orient": "bottom-right",
            "titleFontSize": 10,
            "labelFontSize": 10
          }
        },
        "opacity": {
          "condition": { "param": "playerSelect", "value": 1 },
          "value": 0.1
        },
        "tooltip": [
          { "field": "player",        "title": "Player" },
          { "field": "discipline",    "title": "Discipline" },
          { "field": "year",          "title": "Year" },
          { "field": "world_ranking", "title": "World Ranking" },
          { "field": "points",        "title": "Points", "format": "," }
        ]
      }
    },
    {
      "comment": "── Paris Olympics annotation ──",
      "data": { "values": [{ "year": "2024", "note": "Paris Olympics" }] },
      "mark": { "type": "text", "align": "left", "dx": 5, "dy": -10, "fontSize": 10, "color": "#C47D2A", "fontWeight": "bold" },
      "encoding": {
        "x": { "field": "year", "type": "ordinal" },
        "y": { "value": 20 },
        "text": { "field": "note" }
      }
    },
    {
      "comment": "── Paris Olympics rule ──",
      "data": { "values": [{ "year": "2024" }] },
      "mark": { "type": "rule", "strokeDash": [4,3], "color": "#DFA054", "strokeWidth": 1, "opacity": 0.6 },
      "encoding": { "x": { "field": "year", "type": "ordinal" } }
    }
  ],
  "autosize": { "type": "fit", "contains": "padding" },
  "padding": 4
}