{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Bubble chart — BWF tournaments in Australia: prize money vs BWF points, sized by entries",
  "width": 500,
  "height": 340,
  "background": "#FAFAF8",
  "config": { "view": { "stroke": null } },

  "data": { "url": "data/bwf_tournaments_australia.csv" },

  "transform": [{ "filter": "datum.prize_money_usd > 0" }],

  "mark": { "type": "circle", "opacity": 0.82, "stroke": "white", "strokeWidth": 1.5 },

  "encoding": {
    "x": {
      "field": "prize_money_usd",
      "type": "quantitative",
      "axis": { "title": "Prize Money (USD)", "titleFontSize": 11, "format": "$,.0f" },
      "scale": { "domain": [50000, 950000] }
    },
    "y": {
      "field": "bwf_points_winner",
      "type": "quantitative",
      "axis": { "title": "BWF Points (winner)", "titleFontSize": 11, "format": "," },
      "scale": { "domain": [2000, 7000] }
    },
    "size": {
      "field": "total_entries",
      "type": "quantitative",
      "scale": { "range": [100, 1400] },
      "legend": { "title": "Total entries", "orient": "bottom-right" }
    },
    "color": {
      "field": "grade",
      "type": "nominal",
      "scale": {
        "domain": ["Super 500", "Super 300", "International Challenge"],
        "range": ["#E64A19", "#FFB300", "#1E88E5"]
      },
      "legend": { "title": "Tournament Grade", "orient": "top-left" }
    },
    "tooltip": [
      { "field": "tournament",        "title": "Tournament" },
      { "field": "year",              "title": "Year" },
      { "field": "grade",             "title": "Grade" },
      { "field": "prize_money_usd",   "title": "Prize Money (USD)", "format": "$,.0f" },
      { "field": "bwf_points_winner", "title": "Points (winner)", "format": "," },
      { "field": "total_entries",     "title": "Total entries" },
      { "field": "host_city",         "title": "Host city" }
    ]
  },

  "title": {
    "text": "Australia's Badminton Tournament Ecosystem",
    "subtitle": "Prize money vs. BWF ranking points · Bubble size = total entries · Source: BWF World Tour results",
    "fontSize": 15, "subtitleFontSize": 10, "subtitleColor": "#666", "anchor": "start"
  }
}
