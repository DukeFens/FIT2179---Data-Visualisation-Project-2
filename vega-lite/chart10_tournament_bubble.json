{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 320,
  "background": null,
  "config": { "view": { "stroke": null } },
  "data": { "url": "../data/bwf_tournaments_australia.csv" },
  "transform": [
    { "filter": "datum.prize_money_usd > 0" }
  ],
  "mark": { "type": "circle", "opacity": 0.85, "stroke": "#FAFAF7", "strokeWidth": 1.5 },
  "encoding": {
    "x": {
      "field": "prize_money_usd", "type": "quantitative",
      "axis": { "title": "Prize Money (USD)", "titleFontSize": 10.5, "format": "$,.0f" },
      "scale": { "domain": [50000, 950000] }
    },
    "y": {
      "field": "bwf_points_winner", "type": "quantitative",
      "axis": { "title": "BWF Points (winner)", "titleFontSize": 10.5, "format": "," },
      "scale": { "domain": [2000, 7000] }
    },
    "size": {
      "field": "total_entries", "type": "quantitative",
      "scale": { "range": [100, 1400] },
      "legend": { "title": "Total entries", "orient": "bottom-right", "titleFontSize": 10, "labelFontSize": 10 }
    },
    "color": {
      "field": "grade", "type": "nominal",
      "scale": {
        "domain": ["Super 500","Super 300","International Challenge"],
        "range": ["#8B5318","#C47D2A","#DFA054"]
      },
      "legend": { "title": "Tournament Grade", "orient": "top-left", "titleFontSize": 10, "labelFontSize": 10 }
    },
    "tooltip": [
      { "field": "tournament",        "title": "Tournament" },
      { "field": "year",              "title": "Year" },
      { "field": "grade",             "title": "Grade" },
      { "field": "prize_money_usd",   "title": "Prize Money (USD)", "format": "$,.0f" },
      { "field": "bwf_points_winner", "title": "Points (winner)", "format": "," },
      { "field": "total_entries",     "title": "Total entries" },
      { "field": "host_city",         "title": "Host city" }
    ]
  },
  "autosize": { "type": "fit", "contains": "padding" },
  "padding": 4
}