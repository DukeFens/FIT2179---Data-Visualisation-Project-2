{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container", "height": 300,
  "config": {
    "view": {"stroke": null},
    "font": "Inter, sans-serif",
    "axis": {"labelColor": "#506158", "titleColor": "#506158", "labelFontSize": 11, "titleFontSize": 11, "grid": false, "domainColor": "#C9D4CC", "tickColor": "#C9D4CC"}
  },
  "title": {
    "text": "The badminton talent pipeline",
    "subtitle": "Estimated players at each level (log scale)",
    "anchor": "start", "fontSize": 14, "subtitleFontSize": 11,
    "color": "#172821", "subtitleColor": "#506158", "offset": 12
  },
  "data": {
    "url": "data/talent_pipeline.csv",
    "format": {"type": "csv", "parse": {"estimated_players": "number"}}
  },
  "encoding": {
    "y": {
      "field": "level", "type": "nominal",
      "sort": {"field": "estimated_players", "order": "descending"},
      "title": null,
      "axis": {"labelFontWeight": "700", "labelColor": "#172821", "labelFontSize": 12, "labelPadding": 8}
    }
  },
  "layer": [
    {
      "mark": {"type": "bar", "height": 22, "cornerRadiusEnd": 3},
      "encoding": {
        "x": {
          "field": "estimated_players", "type": "quantitative",
          "scale": {"type": "log", "domain": [10, 60000]},
          "axis": {"title": "Estimated players (log scale)", "values": [10, 100, 1000, 10000], "format": ","}
        },
        "color": {
          "field": "level", "type": "ordinal",
          "sort": {"field": "estimated_players", "order": "descending"},
          "scale": {"range": ["#5BAE7C", "#3F9A66", "#2C8454", "#1E6B41", "#13502F"]},
          "legend": null
        },
        "tooltip": [
          {"field": "level", "title": "Stage"},
          {"field": "program", "title": "Program"},
          {"field": "estimated_players", "title": "Players", "format": ","},
          {"field": "age_range", "title": "Age range"},
          {"field": "next_level_pct", "title": "Advance to next (%)"}
        ]
      }
    },
    {
      "mark": {"type": "text", "align": "left", "dx": 6, "fontSize": 11, "fontWeight": "700", "color": "#172821"},
      "encoding": {
        "x": {"field": "estimated_players", "type": "quantitative", "scale": {"type": "log", "domain": [10, 60000]}},
        "text": {"field": "estimated_players", "type": "quantitative", "format": ","}
      }
    }
  ]
}
