{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": { "step": 56 },
  "data": { "url": "../data/talent_pipeline.csv" },
  "config": {
    "view": { "stroke": null },
    "font": "Inter, sans-serif"
  },
  "transform": [
    { "calculate": "-datum.estimated_players / 2", "as": "x_start" },
    { "calculate": "datum.estimated_players / 2", "as": "x_end" }
  ],
  "layer": [
    {
      "comment": "── Funnel bars ──",
      "mark": { "type": "bar", "cornerRadius": 3 },
      "encoding": {
        "y": {
          "field": "level",
          "type": "ordinal",
          "sort": ["Elite", "National", "State", "Club", "Grassroots"],
          "title": null,
          "axis": {
            "grid": false,
            "labelFontSize": 13,
            "labelColor": "#506158",
            "domainColor": "#C8D5CB",
            "tickColor": "#C8D5CB"
          }
        },
        "x": {
          "field": "x_start",
          "type": "quantitative",
          "scale": { "type": "symlog", "constant": 10 },
          "title": null,
          "axis": { "labels": false, "ticks": false, "domain": false, "grid": false }
        },
        "x2": { "field": "x_end" },
        "color": {
          "field": "level",
          "type": "nominal",
          "scale": {
            "domain": ["Grassroots", "Club", "State", "National", "Elite"],
            "range": ["#DDE5DF", "#C8D5CB", "#B0C4B6", "#4AB87D", "#1A7A4C"]
          },
          "legend": null
        },
        "tooltip": [
          { "field": "level", "title": "Level" },
          { "field": "program", "title": "Program" },
          { "field": "estimated_players", "title": "Players", "format": "," },
          { "field": "next_level_pct", "title": "% advancing" }
        ]
      }
    },
    {
      "comment": "── Player count label (centre of bar) ──",
      "mark": { "type": "text", "align": "center", "fontSize": 12, "fontWeight": "700", "color": "#172821" },
      "encoding": {
        "y": {
          "field": "level",
          "type": "ordinal",
          "sort": ["Elite", "National", "State", "Club", "Grassroots"]
        },
        "x": { "datum": 0 },
        "text": { "field": "estimated_players", "type": "quantitative", "format": ",~s" }
      }
    },
    {
      "comment": "── Sharpest drop annotation: Club → State (92% do not advance) ──",
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 8,
        "fontSize": 11,
        "fontStyle": "italic",
        "color": "#C1503E"
      },
      "encoding": {
        "y": {
          "field": "level",
          "type": "ordinal",
          "sort": ["Elite", "National", "State", "Club", "Grassroots"]
        },
        "x": { "field": "x_end", "type": "quantitative", "scale": { "type": "symlog", "constant": 10 } },
        "text": {
          "condition": {
            "test": "datum.level === 'Club'",
            "value": "↓ 92% do not advance"
          },
          "value": ""
        }
      }
    }
  ]
}
