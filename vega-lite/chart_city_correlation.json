{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container", "height": 300,
  "config": {"view": {"stroke": null}, "font": "Inter, sans-serif"},
  "title": {
    "text": "Courts follow diaspora concentration",
    "subtitle": "Asian-born share vs registered courts by LGA",
    "anchor": "start", "fontSize": 14, "subtitleFontSize": 11,
    "color": "#172821", "subtitleColor": "#506158", "offset": 8
  },
  "data": {
    "url": "data/melbourne_lga_merged.csv",
    "format": {"type": "csv", "parse": {"asian_born_pct": "number", "courts": "number"}}
  },
  "transform": [
    {"filter": "datum.asian_born_pct != null && datum.courts > 0"}
  ],
  "layer": [
    {
      "transform": [
        {"regression": "courts", "on": "asian_born_pct"}
      ],
      "mark": {"type": "line", "color": "#C8D5CB", "strokeWidth": 2, "strokeDash": [6, 3]}
    },
    {
      "mark": {"type": "circle", "size": 160, "stroke": "#F3F6F0", "strokeWidth": 1.5, "color": "#1A7A4C"},
      "encoding": {
        "x": {
          "field": "asian_born_pct", "type": "quantitative",
          "title": "Asian-born residents (%)",
          "axis": {"grid": true, "gridColor": "#E8EDE9", "labelFontSize": 11}
        },
        "y": {
          "field": "courts", "type": "quantitative",
          "title": "Badminton courts",
          "axis": {"grid": true, "gridColor": "#E8EDE9", "labelFontSize": 11}
        },
        "tooltip": [
          {"field": "lga", "title": "LGA"},
          {"field": "asian_born_pct", "title": "Asian-born (%)", "format": ".1f"},
          {"field": "courts", "title": "Courts"}
        ]
      }
    },
    {
      "transform": [
        {"filter": "datum.courts >= 14 || datum.asian_born_pct >= 22"}
      ],
      "mark": {"type": "text", "dy": -12, "fontSize": 10, "fontWeight": "600", "color": "#172821"},
      "encoding": {
        "x": {"field": "asian_born_pct", "type": "quantitative"},
        "y": {"field": "courts", "type": "quantitative"},
        "text": {"field": "lga"}
      }
    },
    {
      "data": {"values": [{"label": "Where diaspora lives, courts tend to follow — a moderate-to-strong correlation"}]},
      "mark": {"type": "text", "align": "left", "fontSize": 10, "fontStyle": "italic", "fontWeight": "600", "color": "#1A7A4C"},
      "encoding": {
        "x": {"value": 0},
        "y": {"value": -12},
        "text": {"field": "label"}
      }
    }
  ],
  "encoding": {
    "x": {"field": "asian_born_pct", "type": "quantitative"},
    "y": {"field": "courts", "type": "quantitative"}
  }
}
