{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 300,
  "data": {
    "url": "data/calorie_burn_activities.csv"
  },
  "config": {
    "view": {
      "stroke": null
    },
    "font": "Inter, sans-serif"
  },
  "transform": [
    {
      "filter": "datum.activity !== 'Cafe/Hospitality Work' && datum.activity !== 'Office/Coding'"
    },
    {
      "calculate": "datum.activity + ' \u2014 ' + datum.intensity",
      "as": "label"
    },
    {
      "calculate": "datum.activity === 'Badminton' ? 'Badminton' : 'Other'",
      "as": "highlight"
    }
  ],
  "layer": [
    {
      "comment": "\u2500\u2500 Connecting line between Social and Competitive within same activity \u2500\u2500",
      "transform": [
        {
          "joinaggregate": [
            {
              "op": "min",
              "field": "calories_per_hour_70kg",
              "as": "cal_min"
            },
            {
              "op": "max",
              "field": "calories_per_hour_70kg",
              "as": "cal_max"
            }
          ],
          "groupby": [
            "activity"
          ]
        },
        {
          "filter": "datum.cal_min !== datum.cal_max"
        }
      ],
      "mark": {
        "type": "rule",
        "strokeWidth": 1.5,
        "opacity": 0.4
      },
      "encoding": {
        "y": {
          "field": "activity",
          "type": "nominal",
          "sort": {
            "field": "calories_per_hour_70kg",
            "order": "descending"
          },
          "title": null,
          "axis": {
            "grid": false,
            "labelFontSize": 12,
            "labelColor": "#506158",
            "domainColor": "#C8D5CB",
            "tickColor": "#C8D5CB"
          }
        },
        "x": {
          "field": "cal_min",
          "type": "quantitative"
        },
        "x2": {
          "field": "cal_max"
        },
        "color": {
          "field": "highlight",
          "type": "nominal",
          "scale": {
            "domain": [
              "Badminton",
              "Other"
            ],
            "range": [
              "#1A7A4C",
              "#C8D5CB"
            ]
          },
          "legend": null
        }
      }
    },
    {
      "comment": "\u2500\u2500 Dots per intensity level \u2500\u2500",
      "mark": {
        "type": "circle",
        "size": 90,
        "stroke": "#F3F6F0",
        "strokeWidth": 1.5
      },
      "encoding": {
        "y": {
          "field": "activity",
          "type": "nominal",
          "sort": {
            "field": "calories_per_hour_70kg",
            "order": "descending"
          },
          "title": null
        },
        "x": {
          "field": "calories_per_hour_70kg",
          "type": "quantitative",
          "title": "Calories burned / hr (70 kg adult)",
          "axis": {
            "grid": true,
            "gridColor": "#E8EDE9",
            "domainColor": "#C8D5CB",
            "tickColor": "#C8D5CB",
            "labelFontSize": 11
          }
        },
        "color": {
          "field": "highlight",
          "type": "nominal",
          "scale": {
            "domain": [
              "Badminton",
              "Other"
            ],
            "range": [
              "#1A7A4C",
              "#839489"
            ]
          },
          "legend": null
        },
        "opacity": {
          "field": "intensity",
          "type": "nominal",
          "scale": {
            "range": [
              0.5,
              1.0
            ]
          },
          "legend": null
        },
        "tooltip": [
          {
            "field": "activity",
            "title": "Activity"
          },
          {
            "field": "intensity",
            "title": "Intensity"
          },
          {
            "field": "calories_per_hour_70kg",
            "title": "Cal / hr"
          },
          {
            "field": "MET",
            "title": "MET score"
          }
        ]
      }
    },
    {
      "comment": "\u2500\u2500 Badminton Social label (below dot) \u2500\u2500",
      "transform": [
        {
          "filter": "datum.activity === 'Badminton' && datum.intensity === 'Social/Recreational'"
        }
      ],
      "mark": {
        "type": "text",
        "align": "center",
        "dy": 14,
        "fontSize": 10,
        "fontWeight": "600",
        "color": "#1A7A4C"
      },
      "encoding": {
        "y": {
          "field": "activity",
          "type": "nominal",
          "sort": {
            "field": "calories_per_hour_70kg",
            "order": "descending"
          }
        },
        "x": {
          "field": "calories_per_hour_70kg",
          "type": "quantitative"
        },
        "text": {
          "value": "Social"
        }
      }
    },
    {
      "comment": "\u2500\u2500 Badminton Competitive label (above dot) \u2500\u2500",
      "transform": [
        {
          "filter": "datum.activity === 'Badminton' && datum.intensity === 'Competitive'"
        }
      ],
      "mark": {
        "type": "text",
        "align": "center",
        "dy": -12,
        "fontSize": 10,
        "fontWeight": "600",
        "color": "#1A7A4C"
      },
      "encoding": {
        "y": {
          "field": "activity",
          "type": "nominal",
          "sort": {
            "field": "calories_per_hour_70kg",
            "order": "descending"
          }
        },
        "x": {
          "field": "calories_per_hour_70kg",
          "type": "quantitative"
        },
        "text": {
          "value": "Competitive"
        }
      }
    },
    {
      "comment": "\u2500\u2500 Average line \u2500\u2500",
      "mark": {
        "type": "rule",
        "color": "#839489",
        "strokeDash": [
          4,
          3
        ],
        "strokeWidth": 1.2,
        "opacity": 0.7
      },
      "encoding": {
        "x": {
          "aggregate": "mean",
          "field": "calories_per_hour_70kg"
        }
      }
    }
  ],
  "title": {
    "anchor": "start",
    "fontSize": 13,
    "subtitleFontSize": 10,
    "color": "#172821",
    "subtitleColor": "#506158",
    "offset": 8,
    "text": "Energy expenditure per hour",
    "subtitle": "Based on a 70-kg adult."
  }
}