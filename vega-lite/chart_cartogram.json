{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 420,
  "config": {"view": {"stroke": null}, "font": "Inter, sans-serif"},
  "title": {
    "text": "Australia resized by badminton players",
    "subtitle": "Circle area = participants; colour = players per thousand residents",
    "anchor": "start", "fontSize": 14, "subtitleFontSize": 11,
    "color": "#172821", "subtitleColor": "#506158", "offset": 8
  },
  "data": {
    "url": "data/cartogram_dorling.csv",
    "format": {"type": "csv", "parse": {"x": "number", "y": "number", "radius": "number", "area": "number", "participants_thousands": "number", "population_millions": "number", "participation_rate_per_million": "number"}}
  },
  "layer": [
    {
      "mark": {"type": "circle", "stroke": "#F3F6F0", "strokeWidth": 2},
      "encoding": {
        "x": {"field": "x", "type": "quantitative", "scale": {"domain": [80, 750]}, "axis": null},
        "y": {"field": "y", "type": "quantitative", "scale": {"domain": [-20, 500]}, "axis": null},
        "size": {"field": "area", "type": "quantitative", "scale": null, "legend": null},
        "color": {
          "field": "participation_rate_per_million", "type": "quantitative",
          "scale": {"range": ["#5BAE7C", "#3F9A66", "#2C8454", "#1E6B41", "#13502F"], "domain": [12, 35]},
          "legend": {"orient": "bottom", "title": "Players per thousand residents", "direction": "horizontal", "gradientLength": 160}
        },
        "tooltip": [
          {"field": "state", "title": "State"},
          {"field": "participants_thousands", "title": "Players (thousands)", "format": ".1f"},
          {"field": "population_millions", "title": "Population (millions)", "format": ".2f"},
          {"field": "participation_rate_per_million", "title": "Per thousand", "format": ".0f"}
        ]
      }
    },
    {
      "mark": {"type": "text", "fontSize": 13, "fontWeight": "700", "color": "#172821"},
      "encoding": {
        "x": {"field": "x", "type": "quantitative", "scale": {"domain": [80, 750]}, "axis": null},
        "y": {"field": "y", "type": "quantitative", "scale": {"domain": [-20, 500]}, "axis": null},
        "text": {"field": "state"}
      }
    }
  ]
}
