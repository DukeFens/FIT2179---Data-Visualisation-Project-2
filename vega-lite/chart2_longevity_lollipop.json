{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 300,
  "background": null,
  "config": { "view": { "stroke": null } },
  "data": { "url": "data/longevity_sports.csv" },
  "layer": [
    {
      "comment": "── Lollipop stem ──",
      "mark": { "type": "rule", "strokeWidth": 2, "opacity": 0.6 },
      "encoding": {
        "x": {
          "field": "sport", "type": "nominal",
          "sort": { "field": "years_gained", "order": "descending" },
          "axis": { "title": null, "labelAngle": -32, "labelFontSize": 11, "labelColor": "#6B6760" }
        },
        "y": { "datum": 0, "type": "quantitative" },
        "y2": { "field": "years_gained", "type": "quantitative" },
        "color": {
          "field": "category", "type": "nominal",
          "scale": {
            "domain": ["Racket", "Aerobic", "Team"],
            "range": ["#C47D2A", "#C8C4BC", "#DFA054"]
          }
        }
      }
    },
    {
      "comment": "── Dot ──",
      "mark": { "type": "circle", "size": 160, "opacity": 0.95 },
      "encoding": {
        "x": {
          "field": "sport", "type": "nominal",
          "sort": { "field": "years_gained", "order": "descending" }
        },
        "y": {
          "field": "years_gained", "type": "quantitative",
          "axis": { "title": "Extra years of life vs sedentary", "titleFontSize": 10.5 }
        },
        "color": {
          "field": "category", "type": "nominal",
          "scale": {
            "domain": ["Racket", "Aerobic", "Team"],
            "range": ["#C47D2A", "#C8C4BC", "#DFA054"]
          },
          "legend": {
            "title": "Sport Category",
            "orient": "top-left",
            "direction": "horizontal",
            "titleFontSize": 10,
            "labelFontSize": 10
          }
        },
        "tooltip": [
          { "field": "sport", "title": "Sport" },
          { "field": "years_gained", "title": "Years gained", "format": ".1f" },
          { "field": "category", "title": "Category" },
          { "field": "mortality_reduction_pct", "title": "Mortality reduction (%)" }
        ]
      }
    },
    {
      "comment": "── Value labels ──",
      "mark": { "type": "text", "align": "center", "dy": -12, "fontSize": 10.5, "fontWeight": "bold" },
      "encoding": {
        "x": {
          "field": "sport", "type": "nominal",
          "sort": { "field": "years_gained", "order": "descending" }
        },
        "y": { "field": "years_gained", "type": "quantitative" },
        "text": { "field": "years_gained", "type": "quantitative", "format": ".1f" },
        "color": {
          "field": "category", "type": "nominal",
          "scale": {
            "domain": ["Racket", "Aerobic", "Team"],
            "range": ["#8B5318", "#9B9690", "#C47D2A"]
          }
        }
      }
    },
    {
      "comment": "── Badminton annotation ──",
      "data": { "values": [{ "x": "Badminton", "y": 6.2, "note": "Badminton +6.2 yrs" }] },
      "mark": {
        "type": "text", "align": "left", "dx": 8, "dy": -6,
        "fontSize": 10, "color": "#8B5318", "fontStyle": "italic", "fontWeight": "bold"
      },
      "encoding": {
        "x": { "field": "x", "type": "nominal" },
        "y": { "field": "y", "type": "quantitative" },
        "text": { "field": "note" }
      }
    }
  ],
  "autosize": { "type": "fit", "contains": "padding" },
  "padding": 4
}