{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 300,
  "background": null,
  "config": { "view": { "stroke": null } },
  "data": { "url": "../data/badminton_participation_trend.csv" },
  "layer": [
    {
      "comment": "── Stacked area by gender ──",
      "transform": [
        {
          "fold": ["male_participants_thousands","female_participants_thousands"],
          "as": ["gender_key","participants"]
        },
        {
          "calculate": "datum.gender_key === 'male_participants_thousands' ? 'Male' : 'Female'",
          "as": "gender"
        }
      ],
      "mark": {
        "type": "area",
        "opacity": 0.2,
        "line": { "strokeWidth": 2 }
      },
      "encoding": {
        "x": {
          "field": "year", "type": "ordinal",
          "axis": { "title": null, "labelFontSize": 11, "labelAngle": 0 }
        },
        "y": {
          "field": "participants", "type": "quantitative",
          "stack": "zero",
          "axis": { "title": "Participants (thousands)", "titleFontSize": 10.5 }
        },
        "color": {
          "field": "gender", "type": "nominal",
          "scale": { "domain": ["Male","Female"], "range": ["#8B5318","#DFA054"] },
          "legend": { "title": "Gender", "orient": "top-right", "titleFontSize": 10, "labelFontSize": 10 }
        },
        "tooltip": [
          { "field": "year", "title": "Year" },
          { "field": "gender", "title": "Gender" },
          { "field": "participants", "title": "Players (thousands)", "format": ".1f" },
          { "field": "data_source", "title": "Survey method" }
        ]
      }
    },
    {
      "comment": "── Methodology break annotation ──",
      "data": { "values": [{ "year": "2024", "note": "← Phone survey   Online survey →" }] },
      "mark": { "type": "text", "align": "center", "dy": -14, "fontSize": 9, "color": "#9B9690", "fontStyle": "italic" },
      "encoding": {
        "x": { "field": "year", "type": "ordinal" },
        "y": { "value": 18 },
        "text": { "field": "note" }
      }
    },
    {
      "comment": "── Dashed break line ──",
      "data": { "values": [{ "year": "2024" }] },
      "mark": { "type": "rule", "strokeDash": [5,4], "color": "#C8C4BC", "strokeWidth": 1.5 },
      "encoding": { "x": { "field": "year", "type": "ordinal" } }
    },
    {
      "comment": "── COVID dip annotation ──",
      "data": { "values": [{ "year": "2020", "note": "COVID-19 dip" }] },
      "mark": { "type": "text", "align": "center", "dy": -10, "fontSize": 9, "color": "#C47D2A", "fontWeight": "bold" },
      "encoding": {
        "x": { "field": "year", "type": "ordinal" },
        "y": { "value": 40 },
        "text": { "field": "note" }
      }
    }
  ],
  "autosize": { "type": "fit", "contains": "padding" },
  "padding": 4
}