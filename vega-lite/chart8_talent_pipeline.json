{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 280,
  "background": null,
  "config": { "view": { "stroke": null } },
  "data": { "url": "data/talent_pipeline.csv" },
  "layer": [
    {
      "comment": "── Horizontal bars ──",
      "mark": { "type": "bar", "cornerRadiusTopRight": 3, "cornerRadiusBottomRight": 3, "opacity": 0.92 },
      "encoding": {
        "y": {
          "field": "level", "type": "ordinal",
          "sort": ["Grassroots","Club","State","National","Elite"],
          "axis": { "title": null, "labelFontSize": 12, "labelFontWeight": "600" }
        },
        "x": {
          "field": "estimated_players", "type": "quantitative",
          "scale": { "type": "log", "base": 10 },
          "axis": { "title": "Estimated players (log scale)", "titleFontSize": 10.5, "format": "," }
        },
        "color": {
          "field": "level", "type": "nominal",
          "sort": ["Grassroots","Club","State","National","Elite"],
          "scale": {
            "domain": ["Grassroots","Club","State","National","Elite"],
            "range": ["#8B5318","#C47D2A","#DFA054","#EEC98A","#F7EDDA"]
          },
          "legend": null
        },
        "tooltip": [
          { "field": "level",            "title": "Level" },
          { "field": "program",          "title": "Program" },
          { "field": "estimated_players","title": "Estimated players", "format": "," },
          { "field": "age_range",        "title": "Age range" },
          { "field": "description",      "title": "Description" }
        ]
      }
    },
    {
      "comment": "── Player count labels ──",
      "mark": { "type": "text", "align": "left", "dx": 8, "fontSize": 11, "fontWeight": "600", "color": "#3D3B35" },
      "encoding": {
        "y": {
          "field": "level", "type": "ordinal",
          "sort": ["Grassroots","Club","State","National","Elite"]
        },
        "x": {
          "field": "estimated_players", "type": "quantitative",
          "scale": { "type": "log", "base": 10 }
        },
        "text": { "field": "estimated_players", "type": "quantitative", "format": "," }
      }
    }
  ],
  "autosize": { "type": "fit", "contains": "padding" },
  "padding": 4
}