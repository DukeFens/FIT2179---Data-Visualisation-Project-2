{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Isotype-style funnel — badminton talent pipeline from Sporting Schools to the Senior Falcons",
  "width": 500,
  "height": 320,
  "background": "#FAFAF8",
  "config": { "view": { "stroke": null } },

  "data": { "url": "data/talent_pipeline.csv" },

  "layer": [
    {
      "comment": "─── Horizontal bars (funnel shape) ───",
      "mark": { "type": "bar", "cornerRadiusTopRight": 4, "cornerRadiusBottomRight": 4, "opacity": 0.9 },
      "encoding": {
        "y": {
          "field": "level",
          "type": "ordinal",
          "sort": ["Grassroots", "Club", "State", "National", "Elite"],
          "axis": { "title": null, "labelFontSize": 12, "labelFontWeight": "bold" }
        },
        "x": {
          "field": "estimated_players",
          "type": "quantitative",
          "scale": { "type": "log", "base": 10 },
          "axis": { "title": "Estimated players (log scale)", "titleFontSize": 11, "format": "," }
        },
        "color": {
          "field": "level",
          "type": "nominal",
          "sort": ["Grassroots", "Club", "State", "National", "Elite"],
          "scale": {
            "domain": ["Grassroots", "Club", "State", "National", "Elite"],
            "range": ["#B3E5FC", "#4FC3F7", "#0288D1", "#01579B", "#E64A19"]
          },
          "legend": null
        },
        "tooltip": [
          { "field": "level",            "title": "Level" },
          { "field": "program",          "title": "Program" },
          { "field": "estimated_players","title": "Estimated players", "format": "," },
          { "field": "age_range",        "title": "Age range" },
          { "field": "description",      "title": "Description" }
        ]
      }
    },
    {
      "comment": "─── Player count labels ───",
      "mark": { "type": "text", "align": "left", "dx": 6, "fontSize": 11, "fontWeight": "bold", "color": "#333" },
      "encoding": {
        "y": {
          "field": "level",
          "type": "ordinal",
          "sort": ["Grassroots", "Club", "State", "National", "Elite"]
        },
        "x": { "field": "estimated_players", "type": "quantitative", "scale": { "type": "log", "base": 10 } },
        "text": { "field": "estimated_players", "type": "quantitative", "format": "," }
      }
    }
  ],

  "title": {
    "text": "From School Yard to World Stage — The Talent Pipeline",
    "subtitle": "Estimated players at each level (log scale) · Source: Badminton Australia Annual Report 2023/24 & BWF records",
    "fontSize": 15, "subtitleFontSize": 10, "subtitleColor": "#666", "anchor": "start"
  }
}
