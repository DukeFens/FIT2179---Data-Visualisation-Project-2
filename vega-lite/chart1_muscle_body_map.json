{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Muscle activation body map during a badminton smash",
  "width": 300,
  "height": 600,
  "background": "transparent",
  "config": { "view": { "stroke": null } },

  "layer": [
    {
      "comment": "── Layer 1: body silhouette image ──",
      "data": { "values": [{ "x": 150, "y": 300 }] },
      "mark": {
        "type": "image",
        "width": 300,
        "height": 600,
        "align": "center",
        "baseline": "middle"
      },
      "encoding": {
        "url": { "value": "../images/body_2.svg" },
        "x": {
          "field": "x",
          "type": "quantitative",
          "scale": { "domain": [0, 300] },
          "axis": null
        },
        "y": {
          "field": "y",
          "type": "quantitative",
          "scale": { "domain": [600, 0] },
          "axis": null
        }
      }
    },
    {
      "comment": "── Layer 2: muscle activation regions (GeoJSON) ──",
      "data": {
        "url": "../data/muscle_regions.geojson",
        "format": { "type": "json", "property": "features" }
      },
      "transform": [
        {
          "lookup": "properties.id",
          "from": {
            "data": { "url": "../data/muscle_activation_smash.csv" },
            "key": "id",
            "fields": ["muscle", "activation_pct_mvic", "body_region", "phase"]
          }
        }
      ],
      "projection": {
        "type": "identity",
        "reflectY": false,
        "translate": [0, 0],
        "scale": 1
      },
      "mark": {
        "type": "geoshape",
        "stroke": "white",
        "strokeWidth": 1.2,
        "opacity": 0.82
      },
      "encoding": {
        "color": {
          "field": "activation_pct_mvic",
          "type": "quantitative",
          "scale": {
            "domain": [30, 55, 75, 90],
            "range": ["#FFF176", "#FFB300", "#E64A19", "#B71C1C"]
          },
          "legend": {
            "title": "Activation (% MVIC)",
            "orient": "bottom",
            "direction": "horizontal",
            "gradientLength": 200,
            "titleFontSize": 11,
            "labelFontSize": 10
          }
        },
        "tooltip": [
          { "field": "muscle", "title": "Muscle" },
          { "field": "body_region", "title": "Region" },
          {
            "field": "activation_pct_mvic",
            "title": "Activation (% MVIC)",
            "format": ".1f"
          },
          { "field": "phase", "title": "Peak Phase" }
        ]
      }
    }
  ],

  "title": {
    "text": "Muscles Fired in a Badminton Smash",
    "subtitle": "Colour = activation level (% MVIC) · Hover for muscle details",
    "fontSize": 15,
    "anchor": "start",
    "offset": 10
  }
}
