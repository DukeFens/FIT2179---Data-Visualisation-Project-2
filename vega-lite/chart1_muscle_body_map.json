{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Muscle activation during a badminton forehand smash — sorted dot chart by activation level",
  "width": 380,
  "height": 340,
  "background": "white",
  "config": {
    "view": { "stroke": null },
    "font": "Segoe UI, Helvetica Neue, Arial, sans-serif",
    "axis": {
      "labelFontSize": 11,
      "titleFontSize": 11,
      "gridColor": "#EEEEEE"
    }
  },

  "data": { "url": "../data/muscle_activation_smash.csv" },

  "layer": [
    {
      "comment": "── Horizontal rule (lollipop stem) ──",
      "mark": { "type": "rule", "strokeWidth": 1.5, "opacity": 0.5 },
      "encoding": {
        "y": {
          "field": "muscle",
          "type": "nominal",
          "sort": { "field": "activation_pct_mvic", "order": "ascending" },
          "axis": { "title": null, "labelFontSize": 11 }
        },
        "x":  { "datum": 0, "type": "quantitative" },
        "x2": { "field": "activation_pct_mvic", "type": "quantitative" },
        "color": {
          "field": "body_region",
          "type": "nominal",
          "scale": {
            "domain": ["Leg", "Core", "Chest", "Shoulder", "Forearm", "Arm", "Back"],
            "range": ["#1E5F74", "#2E86A6", "#27AE60", "#F39C12", "#E64A19", "#8E44AD", "#95A5A6"]
          }
        }
      }
    },
    {
      "comment": "── Dot (lollipop head) ──",
      "mark": { "type": "circle", "size": 120, "opacity": 0.9 },
      "encoding": {
        "y": {
          "field": "muscle",
          "type": "nominal",
          "sort": { "field": "activation_pct_mvic", "order": "ascending" }
        },
        "x": {
          "field": "activation_pct_mvic",
          "type": "quantitative",
          "axis": { "title": "Activation (% MVIC)", "titleFontSize": 11 },
          "scale": { "domain": [0, 100] }
        },
        "color": {
          "field": "body_region",
          "type": "nominal",
          "scale": {
            "domain": ["Leg", "Core", "Chest", "Shoulder", "Forearm", "Arm", "Back"],
            "range": ["#1E5F74", "#2E86A6", "#27AE60", "#F39C12", "#E64A19", "#8E44AD", "#95A5A6"]
          },
          "legend": {
            "title": "Body Region",
            "orient": "bottom-right",
            "titleFontSize": 10,
            "labelFontSize": 10
          }
        },
        "tooltip": [
          { "field": "muscle",             "title": "Muscle" },
          { "field": "body_region",        "title": "Region" },
          { "field": "activation_pct_mvic","title": "Activation (% MVIC)", "format": ".1f" },
          { "field": "phase",              "title": "Peak Phase" }
        ]
      }
    },
    {
      "comment": "── 80% threshold annotation ──",
      "data": { "values": [{ "threshold": 80, "label": "High activation zone" }] },
      "mark": { "type": "rule", "strokeDash": [4,3], "color": "#E64A19", "strokeWidth": 1.2, "opacity": 0.7 },
      "encoding": {
        "x": { "field": "threshold", "type": "quantitative" }
      }
    }
  ],

  "title": {
    "text": "Muscles Fired in a Badminton Smash",
    "subtitle": "Activation level (% MVIC) per muscle · Hover for details · Source: Frontiers in Sports (2025)",
    "fontSize": 15,
    "subtitleFontSize": 10,
    "subtitleColor": "#666",
    "anchor": "start",
    "offset": 10
  }
}
