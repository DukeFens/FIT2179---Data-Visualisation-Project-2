{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Choropleth map of Australia — badminton participation rate by state (AusPlay 2025)",
  "width": 600,
  "height": 380,
  "background": "#EAF4FB",
  "config": { "view": { "stroke": null } },

  "projection": { "type": "mercator" },

  "layer": [
    {
      "comment": "─── State fill by participation rate ───",
      "data": {
        "url": "https://raw.githubusercontent.com/rowanhogan/australian-states/master/states.min.geojson",
        "format": { "type": "json", "property": "features" }
      },
      "transform": [
        {
          "lookup": "properties.STATE_NAME",
          "from": {
            "data": { "url": "data/australia_badminton_participation_by_state.csv" },
            "key": "state",
            "fields": ["participation_rate_pct", "total_participants_thousands", "registered_clubs", "state_code"]
          }
        }
      ],
      "mark": { "type": "geoshape", "stroke": "white", "strokeWidth": 1.2 },
      "encoding": {
        "color": {
          "field": "participation_rate_pct",
          "type": "quantitative",
          "scale": { "scheme": "blues", "domain": [0.5, 2.5] },
          "legend": {
            "title": "Participation rate (%)",
            "orient": "bottom-right",
            "direction": "horizontal",
            "gradientLength": 160,
            "titleFontSize": 11
          }
        },
        "tooltip": [
          { "field": "properties.STATE_NAME",      "title": "State" },
          { "field": "participation_rate_pct",     "title": "Participation rate (%)", "format": ".1f" },
          { "field": "total_participants_thousands","title": "Players (thousands)", "format": ".1f" },
          { "field": "registered_clubs",           "title": "Registered clubs" }
        ]
      }
    },
    {
      "comment": "─── State labels ───",
      "data": {
        "values": [
          { "label": "WA",  "lon": 122.0, "lat": -25.5 },
          { "label": "NT",  "lon": 133.0, "lat": -19.5 },
          { "label": "SA",  "lon": 135.5, "lat": -29.5 },
          { "label": "QLD", "lon": 145.0, "lat": -22.0 },
          { "label": "NSW", "lon": 146.5, "lat": -32.5 },
          { "label": "VIC", "lon": 144.5, "lat": -37.0 },
          { "label": "TAS", "lon": 146.5, "lat": -42.0 },
          { "label": "ACT", "lon": 149.2, "lat": -35.5 }
        ]
      },
      "mark": { "type": "text", "fontSize": 10, "fontWeight": "bold", "color": "#333", "opacity": 0.8 },
      "encoding": {
        "longitude": { "field": "lon", "type": "quantitative" },
        "latitude":  { "field": "lat", "type": "quantitative" },
        "text":      { "field": "label", "type": "nominal" }
      }
    }
  ],

  "title": {
    "text": "Where Does Australia Play Badminton?",
    "subtitle": "Participation rate by state · Source: AusPlay 2025 (Australian Sports Commission, April 2026)",
    "fontSize": 15, "subtitleFontSize": 10, "subtitleColor": "#666", "anchor": "start"
  }
}
